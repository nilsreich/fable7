---
/**
 * Multiple-Choice-Quiz ohne Client-JavaScript.
 *
 * Feedback rein per CSS: Radio-Buttons + :checked zeigen sofort
 * „Richtig“/„Falsch“; bei richtiger Antwort erscheint die Erklärung.
 *
 * Verwendung in MDX:
 *   <Quiz fragen={[
 *     { frage: 'Text (HTML erlaubt, z. B. x&sup2;)', antworten: ['A', 'B', 'C', 'D'],
 *       richtig: 1, erklaerung: 'Kurze Begründung.' },
 *   ]} />
 */
interface Frage {
	frage: string;
	antworten: string[];
	richtig: number; // Index der richtigen Antwort (0-basiert)
	erklaerung?: string;
}

const { fragen } = Astro.props as { fragen: Frage[] };
// Eindeutiges Präfix, falls mehrere Quizze auf einer Seite landen.
// Fortlaufender Zähler statt Zufallswert → deterministische Builds.
const zaehler = ((globalThis as any).__quizZaehler = ((globalThis as any).__quizZaehler ?? 0) + 1);
const uid = `quiz-${zaehler}`;
---

<section class="quiz not-content" aria-label="Quiz zur Selbstkontrolle">
	{
		fragen.map((f, i) => (
			<fieldset class="quiz-frage">
				<legend>
					<span class="quiz-nr">Frage {i + 1} von {fragen.length}</span>
					<span class="quiz-text" set:html={f.frage} />
				</legend>
				<div class="quiz-optionen">
					{f.antworten.map((antwort, j) => {
						const id = `${uid}-${i}-${j}`;
						return (
							<div class={`quiz-option ${j === f.richtig ? 'ist-richtig' : 'ist-falsch'}`}>
								<input type="radio" name={`${uid}-${i}`} id={id} />
								<label for={id}>
									<span class="quiz-buchstabe">{String.fromCharCode(65 + j)}</span>
									<span class="quiz-antwort" set:html={antwort} />
									<span class="quiz-feedback" aria-hidden="true" />
								</label>
							</div>
						);
					})}
				</div>
				{f.erklaerung && (
					<p class="quiz-erklaerung">
						<strong>Erklärung: </strong>
						<span set:html={f.erklaerung} />
					</p>
				)}
			</fieldset>
		))
	}
</section>

<style>
	.quiz {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		margin-top: 1rem;
	}

	.quiz-frage {
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.5rem;
		padding: 1rem 1.25rem 1.25rem;
		background-color: var(--sl-color-gray-7, var(--sl-color-gray-6));
	}

	.quiz-frage legend {
		padding: 0 0.5rem;
	}

	.quiz-nr {
		display: block;
		font-size: var(--sl-text-xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--sl-color-gray-3);
	}

	.quiz-text {
		font-weight: 600;
		color: var(--sl-color-white);
	}

	.quiz-optionen {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		margin-top: 0.5rem;
	}

	/* Radio unsichtbar, aber fokussierbar (Tastaturbedienung) */
	.quiz-option input {
		position: absolute;
		opacity: 0;
		width: 1px;
		height: 1px;
	}

	.quiz-option label {
		display: flex;
		gap: 0.75rem;
		align-items: baseline;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.5rem;
		padding: 0.5rem 0.85rem;
		cursor: pointer;
		background-color: var(--sl-color-bg);
		transition: border-color 0.15s;
	}

	.quiz-option label:hover {
		border-color: var(--sl-color-accent);
	}

	.quiz-option input:focus-visible + label {
		outline: 2px solid var(--sl-color-accent);
		outline-offset: 2px;
	}

	/* Antwortbuchstabe A–D: Referenz für das Abstimmen per Handzeichen */
	.quiz-buchstabe {
		flex-shrink: 0;
		align-self: center;
		display: inline-flex;
		justify-content: center;
		align-items: center;
		width: 1.6em;
		height: 1.6em;
		border: 1px solid var(--sl-color-gray-4);
		border-radius: 50%;
		font-size: var(--sl-text-sm);
		font-weight: 700;
		color: var(--sl-color-gray-2);
	}

	.quiz-antwort {
		flex: 1;
	}

	.quiz-feedback {
		font-weight: 700;
		white-space: nowrap;
	}

	/* Richtig gewählt */
	.quiz-option.ist-richtig input:checked + label {
		border-color: var(--sl-color-green, #2da44e);
		background-color: var(--sl-color-green-low, rgba(45, 164, 78, 0.12));
	}
	.quiz-option.ist-richtig input:checked + label .quiz-feedback::after {
		content: '✓ Richtig!';
		color: var(--sl-color-green, #2da44e);
	}

	/* Falsch gewählt */
	.quiz-option.ist-falsch input:checked + label {
		border-color: var(--sl-color-red, #d1242f);
		background-color: var(--sl-color-red-low, rgba(209, 36, 47, 0.1));
	}
	.quiz-option.ist-falsch input:checked + label .quiz-feedback::after {
		content: '✗ Leider falsch';
		color: var(--sl-color-red, #d1242f);
	}

	/* Erklärung erst zeigen, wenn die richtige Antwort gefunden wurde */
	.quiz-erklaerung {
		display: none;
		margin: 0.85rem 0 0;
		padding: 0.6rem 0.85rem;
		border-inline-start: 3px solid var(--sl-color-green, #2da44e);
		background-color: var(--sl-color-green-low, rgba(45, 164, 78, 0.12));
		border-radius: 0 0.5rem 0.5rem 0;
		font-size: var(--sl-text-sm);
	}

	.quiz-frage:has(.ist-richtig input:checked) .quiz-erklaerung {
		display: block;
	}
</style>
